<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.app.mapper.MstCodeMapper">

	<resultMap id="MstCodeMap"
		type="com.example.app.domain.MstCode">
		<id column="type" property="type" />
		<id column="category" property="category" />
		<id column="code" property="code" />
		<result column="name" property="name" />

	</resultMap>

	<select id="selectByType" resultMap="MstCodeMap">
		SELECT * FROM mst_code WHERE type = #{type}
	</select>


</mapper> 